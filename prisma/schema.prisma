generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum ProjectStatus {
  DRAFT
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  DENIED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum OrganizationActivityType {
  ORGANIZATION_UPDATED
  ORGANIZATION_ARCHIVED
  MEMBER_UPDATED
  MEMBER_REMOVED
  INVITATION_CREATED
  INVITATION_ACCEPTED
  INVITATION_REVOKED
  SETTINGS_UPDATED
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model User {
  id                         String                    @id @default(cuid())
  email                      String                    @unique
  displayName                String?
  passwordHash               String?
  emailVerified              DateTime?
  isPlatformAdmin            Boolean                   @default(false)
  memberships                Membership[]
  ownedProjects              Project[]                 @relation("ProjectOwner")
  auditEvents                AuditEvent[]              @relation("AuditActor")
  createdInvites             OrganizationInvitation[]  @relation("InvitationCreator")
  activities                 OrganizationActivity[]    @relation("ActivityActor")
  sessions                   AuthSession[]
  loginEvents                LoginEvent[]
  emailVerificationTokens    EmailVerificationToken[]
  passwordResetTokens        PasswordResetToken[]
  projectMemberships         ProjectMembership[]
  assignedTasks              ProjectTask[]             @relation("TaskAssignee")
  createdTasks               ProjectTask[]             @relation("TaskCreator")
  projectComments            ProjectComment[]
  uploadedFiles              ProjectAttachment[]
  notifications              UserNotification[]
  notificationPreferences    NotificationPreference[]
  notificationDeliveries     NotificationDelivery[]
  preferredLocale            String                    @default("en-AE")
  realtimeConnections        RealtimeConnection[]
  presenceSessions           PresenceSession[]
  createdChatChannels        ChatChannel[]             @relation("ChatChannelCreator")
  chatChannelMemberships     ChatChannelMember[]
  chatMessages               ChatMessage[]             @relation("ChatMessageAuthor")
  deletedChatMessages        ChatMessage[]             @relation("ChatMessageDeleter")
  chatMessageRevisions       ChatMessageRevision[]     @relation("ChatRevisionEditor")
  chatMentions               ChatMention[]
  chatReactions              ChatReaction[]
  freelancerProfile          FreelancerProfile?
  createdListings            MarketplaceListing[]      @relation("ListingCreator")
  savedListings              SavedListing[]
  submittedProposals         Proposal[]                @relation("ProposalSubmitter")
  decidedProposals           Proposal[]                @relation("ProposalDecider")
  proposalRevisions          ProposalRevision[]        @relation("ProposalRevisionCreator")
  createdContracts           Contract[]                @relation("ContractCreator")
  providerContracts          Contract[]                @relation("ContractProviderUser")
  contractAcceptances        ContractAcceptance[]
  proposedAmendments         ContractAmendment[]       @relation("AmendmentProposer")
  workSubmissions            WorkSubmission[]
  workSubmissionDecisions    WorkSubmissionDecision[]
  reviewsWritten             Review[]                  @relation("ReviewAuthor")
  reviewsReceived            Review[]                  @relation("ReviewSubjectUser")
  disputesOpened             Dispute[]                 @relation("DisputeOpener")
  disputesAgainst            Dispute[]                 @relation("DisputeAgainstUser")
  abuseReports               AbuseReport[]             @relation("AbuseReporter")
  assignedAbuseReports       AbuseReport[]             @relation("AbuseAssignee")
  vendorOnboardings          VendorOnboarding[]        @relation("VendorCandidateUser")
  timeEntries                TimeEntry[]
  timesheets                 Timesheet[]
  createdDeliverables        Deliverable[]             @relation("DeliverableCreator")
  requestedApprovals         ApprovalRequest[]         @relation("ApprovalRequester")
  assignedApprovals          ApprovalRequest[]         @relation("ApprovalAssignee")
  changeRequests             ChangeRequest[]           @relation("ChangeRequester")
  ownedRisks                 ProjectRisk[]             @relation("RiskOwner")
  resourceAllocations        ResourceAllocation[]
  projectTemplates           ProjectTemplate[]         @relation("TemplateCreator")
  createdFileNodes           FileNode[]                @relation("FileNodeCreator")
  uploadedFileVersions       FileVersion[]             @relation("FileVersionUploader")
  createdFileUploadIntents   FileUploadIntent[]        @relation("FileUploadIntentCreator")
  fileLocks                  FileLock[]
  fileAccessGrants           FileAccessGrant[]
  fileActivities             FileActivity[]
  aiRuns                     AiRun[]
  aiPromptVersions           AiPromptVersion[]         @relation("AiPromptVersionCreator")
  requestedAiApprovals       AiApproval[]              @relation("AiApprovalRequester")
  decidedAiApprovals         AiApproval[]              @relation("AiApprovalDecider")
  aiUsageRecords             AiUsageRecord[]
  aiAuditLogs                AiAuditLog[]
  issuedInvoices             Invoice[]                 @relation("InvoiceIssuer")
  requestedRefunds           Refund[]
  creditEntries              CreditLedgerEntry[]
  savedSearches              SavedSearch[]
  searchQueries              SearchQueryLog[]
  securityEvents             SecurityEvent[]
  supportCases               SupportCase[]
  analyticsEvents            AnalyticsEvent[]
  requestedAnalyticsRuns     AnalyticsAggregationRun[] @relation("AnalyticsRunRequester")
  requestedExports           DataExportJob[]
  consentRecords             ConsentRecord[]
  verifiedCredentials        VerifiedCredential[]      @relation("CredentialSubjectUser")
  assignedSupportCases       SupportCase[]             @relation("SupportCaseAssignee")
  idempotencyRecords         IdempotencyRecord[]
  workflowDefinitions        WorkflowDefinition[]      @relation("WorkflowDefinitionCreator")
  workflowRuns               WorkflowRun[]             @relation("WorkflowRunStarter")
  requestedWorkflowApprovals WorkflowApproval[]        @relation("WorkflowApprovalRequester")
  decidedWorkflowApprovals   WorkflowApproval[]        @relation("WorkflowApprovalDecider")
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
}

model Organization {
  id                       String                    @id @default(cuid())
  name                     String
  slug                     String                    @unique
  status                   OrganizationStatus        @default(ACTIVE)
  memberships              Membership[]
  projects                 Project[]
  roles                    Role[]
  auditEvents              AuditEvent[]
  settings                 OrganizationSettings?
  invitations              OrganizationInvitation[]
  activities               OrganizationActivity[]
  chatChannels             ChatChannel[]
  companyProfile           CompanyProfile?
  marketplaceListings      MarketplaceListing[]
  talentPools              TalentPool[]
  vendorOnboardings        VendorOnboarding[]        @relation("VendorClientOrganization")
  vendorRegistrations      VendorOnboarding[]        @relation("VendorOrganization")
  clientContracts          Contract[]                @relation("ContractClientOrganization")
  providerContracts        Contract[]                @relation("ContractProviderOrganization")
  contractAcceptances      ContractAcceptance[]
  submittedProposals       Proposal[]                @relation("ProposalProviderOrganization")
  reviewSubjects           Review[]                  @relation("ReviewSubjectOrganization")
  fileNodes                FileNode[]
  fileUploadIntents        FileUploadIntent[]
  aiConfig                 AiTenantConfig?
  aiPrompts                AiPrompt[]
  aiRuns                   AiRun[]
  aiUsageRecords           AiUsageRecord[]
  aiAuditLogs              AiAuditLog[]
  knowledgeSources         KnowledgeSource[]
  searchDocuments          SearchDocument[]
  searchIndexCheckpoint    SearchIndexCheckpoint?
  savedSearches            SavedSearch[]
  searchQueryLogs          SearchQueryLog[]
  invoices                 Invoice[]
  billedInvoices           Invoice[]                 @relation("InvoiceBillToOrganization")
  financialTransactions    FinancialTransaction[]
  refunds                  Refund[]
  subscription             OrganizationSubscription?
  usageRecords             UsageRecord[]
  creditEntries            CreditLedgerEntry[]
  reconciliationRecords    ReconciliationRecord[]
  organizationFeatureFlags OrganizationFeatureFlag[]
  securityEvents           SecurityEvent[]
  supportCases             SupportCase[]
  branding                 OrganizationBranding?
  policyConfigurations     PolicyConfiguration[]
  consentRecords           ConsentRecord[]
  retentionPolicies        DataRetentionPolicy[]
  analyticsEvents          AnalyticsEvent[]
  analyticsMetrics         AnalyticsDailyMetric[]
  analyticsAggregationRuns AnalyticsAggregationRun[]
  dataExports              DataExportJob[]
  backgroundJobs           BackgroundJob[]
  idempotencyRecords       IdempotencyRecord[]
  verifiedCredentials      VerifiedCredential[]      @relation("CredentialSubjectOrganization")
  webhookReceipts          WebhookReceipt[]
  workGraphNodes           WorkGraphNode[]
  workGraphEdges           WorkGraphEdge[]
  workflowDefinitions      WorkflowDefinition[]
  workflowRuns             WorkflowRun[]
  workflowApprovals        WorkflowApproval[]
  talentMatches            TalentMatch[]
  rateLimitBuckets         RateLimitBucket[]
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  projectTemplates         ProjectTemplate[]
}

model Membership {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  roleId         String?
  status         MembershipStatus @default(INVITED)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           Role?            @relation(fields: [roleId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId, status])
  @@index([userId, status])
}

model Role {
  id               String            @id @default(cuid())
  organizationId   String
  name             String
  description      String?
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships      Membership[]
  permissions      RolePermission[]
  fileAccessGrants FileAccessGrant[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model Project {
  id                   String                  @id @default(cuid())
  organizationId       String
  ownerId              String
  title                String
  slug                 String
  description          String?
  status               ProjectStatus           @default(DRAFT)
  budgetMinor          BigInt?
  currency             String                  @default("AED")
  organization         Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner                User                    @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  memberships          ProjectMembership[]
  milestones           ProjectMilestone[]
  tasks                ProjectTask[]
  comments             ProjectComment[]
  attachments          ProjectAttachment[]
  fileUploadIntents    FileUploadIntent[]
  searchDocuments      SearchDocument[]
  activities           ProjectActivity[]
  realtimeEvents       RealtimeEvent[]
  presenceSessions     PresenceSession[]
  chatChannels         ChatChannel[]
  marketplaceListing   MarketplaceListing?
  contracts            Contract[]
  taskDependenciesFrom TaskDependency[]        @relation("TaskDependencyProject")
  timeEntries          TimeEntry[]
  timesheets           Timesheet[]
  deliverables         Deliverable[]
  approvalRequests     ApprovalRequest[]
  changeRequests       ChangeRequest[]
  risks                ProjectRisk[]
  issues               ProjectIssue[]
  resourceAllocations  ResourceAllocation[]
  healthSnapshots      ProjectHealthSnapshot[]
  fileNodes            FileNode[]
  aiRuns               AiRun[]
  knowledgeSources     KnowledgeSource[]
  analyticsEvents      AnalyticsEvent[]
  workGraphNodes       WorkGraphNode[]
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([ownerId, status])
}

model OrganizationSettings {
  id               String       @id @default(cuid())
  organizationId   String       @unique
  timezone         String       @default("Asia/Dubai")
  defaultCurrency  String       @default("AED")
  defaultLocale    String       @default("en-AE")
  supportedLocales String[]     @default(["en-AE", "ar-AE"])
  dataRegion       String       @default("UAE")
  requireMfa       Boolean      @default(false)
  allowGuestAccess Boolean      @default(false)
  metadata         Json?
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model OrganizationInvitation {
  id             String           @id @default(cuid())
  organizationId String
  email          String
  roleId         String?
  tokenHash      String           @unique
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  createdById    String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User             @relation("InvitationCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId, status])
  @@index([email, status])
}

model OrganizationActivity {
  id             String                   @id @default(cuid())
  organizationId String
  actorUserId    String?
  type           OrganizationActivityType
  resourceType   String
  resourceId     String?
  summary        String
  metadata       Json?
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          User?                    @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime                 @default(now())

  @@index([organizationId, createdAt])
  @@index([type, createdAt])
}

model AuthSession {
  id                   String        @id @default(cuid())
  userId               String
  organizationId       String?
  status               SessionStatus @default(ACTIVE)
  refreshTokenHash     String        @unique
  userAgent            String?
  ipAddress            String?
  deviceLabel          String?
  expiresAt            DateTime
  lastSeenAt           DateTime      @default(now())
  revokedAt            DateTime?
  rotatedFromSessionId String?
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([userId, status])
  @@index([organizationId, status])
  @@index([expiresAt])
}

model LoginEvent {
  id         String   @id @default(cuid())
  userId     String?
  email      String
  outcome    String
  reason     String?
  ipAddress  String?
  userAgent  String?
  occurredAt DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, occurredAt])
  @@index([userId, occurredAt])
  @@index([outcome, occurredAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
}

model AuditEvent {
  id             String        @id @default(cuid())
  organizationId String?
  actorUserId    String?
  action         String
  resourceType   String
  resourceId     String?
  outcome        AuditOutcome
  metadata       Json?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actor          User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([resourceType, resourceId])
  @@index([action, outcome])
}

enum ProjectMemberRole {
  OWNER
  MANAGER
  CONTRIBUTOR
  VIEWER
}

enum ProjectMilestoneStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ProjectTaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
  CANCELLED
}

enum ProjectTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectActivityType {
  PROJECT_UPDATED
  MEMBER_ADDED
  MEMBER_REMOVED
  MILESTONE_CREATED
  MILESTONE_UPDATED
  TASK_CREATED
  TASK_UPDATED
  TASK_ASSIGNED
  COMMENT_CREATED
  ATTACHMENT_ADDED
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

model ProjectMembership {
  id        String            @id @default(cuid())
  projectId String
  userId    String
  role      ProjectMemberRole @default(CONTRIBUTOR)
  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([projectId, userId])
  @@index([userId, role])
  @@index([projectId, role])
}

model ProjectMilestone {
  id                 String                 @id @default(cuid())
  projectId          String
  title              String
  description        String?
  status             ProjectMilestoneStatus @default(PLANNED)
  dueAt              DateTime?
  project            Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks              ProjectTask[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  contractMilestones ContractMilestone[]

  @@index([projectId, status])
  @@index([dueAt])
}

model ProjectTask {
  id               String              @id @default(cuid())
  projectId        String
  milestoneId      String?
  creatorId        String
  assigneeId       String?
  title            String
  description      String?
  status           ProjectTaskStatus   @default(TODO)
  priority         ProjectTaskPriority @default(MEDIUM)
  dueAt            DateTime?
  position         Int                 @default(0)
  metadata         Json?
  parentId         String?
  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone        ProjectMilestone?   @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  creator          User                @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  assignee         User?               @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments         ProjectComment[]
  attachments      ProjectAttachment[]
  parent           ProjectTask?        @relation("ProjectTaskHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  subtasks         ProjectTask[]       @relation("ProjectTaskHierarchy")
  predecessorLinks TaskDependency[]    @relation("TaskPredecessor")
  successorLinks   TaskDependency[]    @relation("TaskSuccessor")
  timeEntries      TimeEntry[]
  deliverables     Deliverable[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([projectId, status, position])
  @@index([assigneeId, status])
  @@index([milestoneId, status])
  @@index([dueAt])
  @@index([parentId, status])
}

model ProjectComment {
  id        String       @id @default(cuid())
  projectId String
  taskId    String?
  authorId  String
  body      String
  metadata  Json?
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      ProjectTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User         @relation(fields: [authorId], references: [id], onDelete: Restrict)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([projectId, createdAt])
  @@index([taskId, createdAt])
}

model ProjectAttachment {
  id             String       @id @default(cuid())
  projectId      String
  taskId         String?
  uploadedById   String
  filename       String
  storageKey     String       @unique
  mimeType       String
  sizeBytes      BigInt
  checksumSha256 String?
  fileVersionId  String       @unique
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task           ProjectTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy     User         @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  fileVersion    FileVersion  @relation(fields: [fileVersionId], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())

  @@index([projectId, createdAt])
  @@index([taskId, createdAt])
}

model ProjectActivity {
  id           String              @id @default(cuid())
  projectId    String
  actorUserId  String?
  type         ProjectActivityType
  resourceType String
  resourceId   String?
  summary      String
  metadata     Json?
  project      Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt    DateTime            @default(now())

  @@index([projectId, createdAt])
  @@index([type, createdAt])
}

model UserNotification {
  id             String                 @id @default(cuid())
  userId         String
  organizationId String?
  projectId      String?
  type           String
  category       String                 @default("GENERAL")
  priority       NotificationPriority   @default(NORMAL)
  title          String
  body           String?
  actionUrl      String?
  dedupeKey      String?                @unique
  status         NotificationStatus     @default(UNREAD)
  metadata       Json?
  expiresAt      DateTime?
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries     NotificationDelivery[]
  createdAt      DateTime               @default(now())
  readAt         DateTime?
  archivedAt     DateTime?

  @@index([userId, status, createdAt])
  @@index([userId, category, createdAt])
  @@index([projectId, createdAt])
  @@index([expiresAt])
}

enum RealtimeEventStatus {
  PENDING
  PUBLISHED
  FAILED
}

enum PresenceStatus {
  ONLINE
  AWAY
  OFFLINE
}

enum ChatChannelType {
  PROJECT
  GROUP
  DIRECT
  ANNOUNCEMENT
}

enum ChatChannelVisibility {
  PRIVATE
  PROJECT
  ORGANIZATION
}

enum ChatMemberRole {
  OWNER
  MODERATOR
  MEMBER
}

enum ChatNotificationLevel {
  ALL
  MENTIONS
  NONE
}

enum ChatMessageFormat {
  PLAIN_TEXT
  MARKDOWN
}

enum ProfileAvailability {
  AVAILABLE
  LIMITED
  UNAVAILABLE
}

enum CredentialStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
  REVOKED
}

enum MarketplaceListingStatus {
  DRAFT
  PUBLISHED
  PAUSED
  AWARDED
  CLOSED
  CANCELLED
}

enum MarketplaceVisibility {
  PUBLIC
  PRIVATE
  TALENT_POOL
  INVITE_ONLY
}

enum EngagementType {
  FIXED_PRICE
  HOURLY
  RETAINER
  EMPLOYMENT
}

enum ExperienceLevel {
  ENTRY
  INTERMEDIATE
  EXPERT
  ENTERPRISE
}

enum ProposalStatus {
  DRAFT
  SUBMITTED
  SHORTLISTED
  REVISION_REQUESTED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ContractStatus {
  DRAFT
  PENDING_SIGNATURES
  ACTIVE
  PAUSED
  COMPLETED
  TERMINATED
  DISPUTED
}

enum AmendmentStatus {
  DRAFT
  PROPOSED
  ACCEPTED
  REJECTED
  SUPERSEDED
}

enum ContractMilestoneStatus {
  PLANNED
  FUNDED
  IN_PROGRESS
  SUBMITTED
  REVISION_REQUESTED
  ACCEPTED
  RELEASE_PENDING
  RELEASED
  CANCELLED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  REVISION_REQUESTED
  ACCEPTED
  REJECTED
}

enum ContractAcceptanceParty {
  CLIENT
  PROVIDER
}

enum ContractAcceptanceMethod {
  CLICKWRAP
  ELECTRONIC_SIGNATURE
}

enum SubmissionDecisionType {
  APPROVED
  REJECTED
  REVISION_REQUESTED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
  REMOVED
}

enum DisputeStatus {
  OPEN
  EVIDENCE_COLLECTION
  MEDIATION
  RESOLVED
  CLOSED
  CANCELLED
}

enum VendorOnboardingStatus {
  INVITED
  IN_PROGRESS
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum AbuseReportStatus {
  OPEN
  TRIAGED
  INVESTIGATING
  ACTIONED
  DISMISSED
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  LOCKED
}

enum WorkspaceApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ChangeRequestStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  IMPLEMENTED
  CANCELLED
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  OPEN
  MITIGATING
  ACCEPTED
  CLOSED
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  RESOLVED
  CLOSED
}

enum FileNodeType {
  FILE
  FOLDER
}

enum FileScanStatus {
  PENDING
  CLEAN
  INFECTED
  FAILED
  NOT_CONFIGURED
}

enum FileUploadIntentStatus {
  ISSUED
  COMPLETED
  FAILED
  EXPIRED
}

enum FileAccessLevel {
  VIEW
  DOWNLOAD
  EDIT
