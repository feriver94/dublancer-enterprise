  updatedAt      DateTime            @updatedAt

  @@index([status, availableAt])
  @@index([organizationId, createdAt])
  @@index([projectId, createdAt])
  @@index([topic, createdAt])
  @@index([aggregateType, aggregateId])
}

model RealtimeConnection {
