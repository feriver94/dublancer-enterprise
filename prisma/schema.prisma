  createdAt      DateTime     @default(now())

  @@index([organizationId, scope, createdAt])
  @@index([queryHash, createdAt])
}

model Invoice {
  id                   String                 @id @default(cuid())
  organizationId       String
  billToOrganizationId String?
  contractId           String?
  issuedById           String
  number               String
  status               InvoiceStatus          @default(DRAFT)
  subtotalMinor        BigInt
  taxMinor             BigInt                 @default(0)
  totalMinor           BigInt
  currency             String                 @default("AED")
  issuedAt             DateTime?
  dueAt                DateTime?
  paidAt               DateTime?
  voidedAt             DateTime?
  version              Int                    @default(1)
  metadata             Json?
  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  billToOrganization   Organization?          @relation("InvoiceBillToOrganization", fields: [billToOrganizationId], references: [id], onDelete: SetNull)
  contract             Contract?              @relation(fields: [contractId], references: [id], onDelete: SetNull)
  issuedBy             User                   @relation("InvoiceIssuer", fields: [issuedById], references: [id], onDelete: Restrict)
  lines                InvoiceLine[]
  paymentSchedules     PaymentSchedule[]
  transactions         FinancialTransaction[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@unique([organizationId, number])
  @@index([organizationId, status, dueAt])
  @@index([billToOrganizationId, status])
  @@index([contractId, status])
}

model InvoiceLine {
  id                 String   @id @default(cuid())
  invoiceId          String
  description        String
  quantity           Int      @default(1)
  unitAmountMinor    BigInt
  taxRateBasisPoints Int      @default(0)
  totalMinor         BigInt
  metadata           Json?
  invoice            Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())

  @@index([invoiceId])
}

model PaymentSchedule {
  id                  String                  @id @default(cuid())
  invoiceId           String?
  contractMilestoneId String?                 @unique
  dueAt               DateTime
  amountMinor         BigInt
  currency            String                  @default("AED")
  status              ContractMilestoneStatus @default(PLANNED)
  invoice             Invoice?                @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  contractMilestone   ContractMilestone?      @relation(fields: [contractMilestoneId], references: [id], onDelete: Cascade)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([invoiceId, dueAt])
  @@index([contractMilestoneId, dueAt])
  @@index([status, dueAt])
}

model FinancialTransaction {
  id              String                     @id @default(cuid())
  organizationId  String
  contractId      String?
  invoiceId       String?
  type            FinancialTransactionType
  status          FinancialTransactionStatus @default(PENDING)
  amountMinor     BigInt
  currency        String                     @default("AED")
  idempotencyKey  String
  providerKey     String?
  providerRef     String?
  failureCode     String?
  failureMessage  String?
  processedAt     DateTime?
  version         Int                        @default(1)
  metadata        Json?
  occurredAt      DateTime                   @default(now())
  organization    Organization               @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  contract        Contract?                  @relation(fields: [contractId], references: [id], onDelete: SetNull)
  invoice         Invoice?                   @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  refunds         Refund[]                   @relation("OriginalTransactionRefunds")
  refundRecord    Refund?                    @relation("RefundTransaction")
  webhookReceipts WebhookReceipt[]
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@unique([organizationId, idempotencyKey])
  @@unique([providerKey, providerRef])
  @@index([organizationId, status, occurredAt])
  @@index([contractId, type])
  @@index([invoiceId, type])
}

model Refund {
  id                  String                @id @default(cuid())
  organizationId      String
  transactionId       String
  refundTransactionId String?               @unique
  requestedById       String
  idempotencyKey      String
  status              RefundStatus          @default(REQUESTED)
  amountMinor         BigInt
  reason              String
  providerRef         String?
  processedAt         DateTime?
  version             Int                   @default(1)
  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  transaction         FinancialTransaction  @relation("OriginalTransactionRefunds", fields: [transactionId], references: [id], onDelete: Restrict)
  refundTransaction   FinancialTransaction? @relation("RefundTransaction", fields: [refundTransactionId], references: [id], onDelete: SetNull)
  requestedBy         User                  @relation(fields: [requestedById], references: [id], onDelete: Restrict)
  webhookReceipts     WebhookReceipt[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@unique([organizationId, idempotencyKey])
  @@index([transactionId, status])
  @@index([organizationId, status, createdAt])
  @@index([requestedById, createdAt])
}

model SubscriptionPlan {
  id            String                     @id @default(cuid())
  code          String                     @unique
  name          String
  description   String?
  priceMinor    BigInt
  currency      String                     @default("AED")
  interval      String                     @default("MONTH")
  entitlements  Json
  isActive      Boolean                    @default(true)
  subscriptions OrganizationSubscription[]
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  @@index([isActive, priceMinor])
}

model OrganizationSubscription {
  id                      String             @id @default(cuid())
  organizationId          String             @unique
  planId                  String
  status                  SubscriptionStatus @default(TRIALING)
  providerKey             String?
  providerCustomerRef     String?
  providerSubscriptionRef String?
  currentPeriodStart      DateTime
  currentPeriodEnd        DateTime
  cancelAtPeriodEnd       Boolean            @default(false)
  organization            Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan                    SubscriptionPlan   @relation(fields: [planId], references: [id], onDelete: Restrict)
  usageRecords            UsageRecord[]
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@index([planId, status])
  @@index([status, currentPeriodEnd])
}

model UsageRecord {
  id             String                    @id @default(cuid())
  organizationId String
  subscriptionId String?
  unit           UsageUnit
  quantity       BigInt
  idempotencyKey String
  periodStart    DateTime
  periodEnd      DateTime
  metadata       Json?
  organization   Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription   OrganizationSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  createdAt      DateTime                  @default(now())

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, unit, periodStart])
  @@index([subscriptionId, periodStart])
}

model CreditLedgerEntry {
  id                String       @id @default(cuid())
  organizationId    String
  userId            String?
  amountMinor       BigInt
  currency          String       @default("AED")
  reason            String
  reference         String
  balanceAfterMinor BigInt
  metadata          Json?
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  user              User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt         DateTime     @default(now())

  @@unique([organizationId, reference])
  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
}

model ReconciliationRecord {
  id               String       @id @default(cuid())
  organizationId   String
  providerKey      String
  periodStart      DateTime
  periodEnd        DateTime
  expectedMinor    BigInt
  actualMinor      BigInt
  differenceMinor  BigInt
  currency         String       @default("AED")
  status           String
  evidence         Json?
  eventCount       Int          @default(0)
  lastReconciledAt DateTime?
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([organizationId, providerKey, periodStart, periodEnd])
  @@index([organizationId, status, periodEnd])
}

model WebhookReceipt {
  id                String                  @id @default(cuid())
  organizationId    String?
  providerKey       String
  eventId           String
  eventType         String?
  providerRef       String?
  transactionId     String?
  refundId          String?
  payloadHash       String
  signatureVerified Boolean                 @default(false)
  processingStatus  WebhookProcessingStatus @default(RECEIVED)
  receivedAt        DateTime                @default(now())
  processedAt       DateTime?
  failureReason     String?
  organization      Organization?           @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  transaction       FinancialTransaction?   @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  refund            Refund?                 @relation(fields: [refundId], references: [id], onDelete: SetNull)

  @@unique([providerKey, eventId])
  @@index([organizationId, receivedAt])
  @@index([processedAt, receivedAt])
  @@index([providerKey, providerRef])
  @@index([processingStatus, receivedAt])
}

model FeatureFlag {
  id          String                    @id @default(cuid())
  key         String                    @unique
  description String?
  enabled     Boolean                   @default(false)
  rules       Json?
  overrides   OrganizationFeatureFlag[]
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
}

model OrganizationFeatureFlag {
  organizationId String
  featureFlagId  String
  enabled        Boolean
  configuration  Json?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  featureFlag    FeatureFlag  @relation(fields: [featureFlagId], references: [id], onDelete: Cascade)
  updatedAt      DateTime     @updatedAt

  @@id([organizationId, featureFlagId])
  @@index([featureFlagId, enabled])
}

model SecurityEvent {
  id             String                @id @default(cuid())
  organizationId String?
  userId         String?
  type           String
  severity       SecurityEventSeverity
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  resolvedAt     DateTime?
  organization   Organization?         @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user           User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime              @default(now())

  @@index([organizationId, severity, createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@index([resolvedAt, severity])
}

model SupportCase {
  id             String              @id @default(cuid())
  organizationId String
  requesterId    String
  assignedToId   String?
  number         String              @unique
  subject        String
  description    String
  status         SupportCaseStatus   @default(OPEN)
  priority       SupportCasePriority @default(NORMAL)
  resolution     String?
  resolvedAt     DateTime?
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requester      User                @relation(fields: [requesterId], references: [id], onDelete: Restrict)
  assignedTo     User?               @relation("SupportCaseAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId, status, updatedAt])
  @@index([assignedToId, status])
}

model OrganizationBranding {
  id             String       @id @default(cuid())
  organizationId String       @unique
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  fontFamily     String?
  customDomain   String?
  metadata       Json?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model PolicyConfiguration {
  id             String       @id @default(cuid())
  organizationId String
  key            String
  version        Int          @default(1)
  value          Json
  effectiveAt    DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId, effectiveAt])
}

model ConsentRecord {
  id             String        @id @default(cuid())
  organizationId String?
  userId         String
  purpose        String
  policyVersion  String
  status         ConsentStatus @default(GRANTED)
  grantedAt      DateTime      @default(now())
  revokedAt      DateTime?
  evidence       Json?
