  @@unique([userId, connectionId])
  @@index([organizationId, status, expiresAt])
  @@index([projectId, status, expiresAt])
  @@index([resourceType, resourceId, status])
}

model ChatChannel {
  id             String                @id @default(cuid())
  organizationId String
  projectId      String?
  createdById    String
  type           ChatChannelType
  visibility     ChatChannelVisibility @default(PRIVATE)
  name           String?
  slug           String?
  description    String?
  directKey      String?               @unique
  sequence       BigInt                @default(0)
  lastMessageAt  DateTime?
  retentionDays  Int?
  isArchived     Boolean               @default(false)
  metadata       Json?
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy      User                  @relation("ChatChannelCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members        ChatChannelMember[]
  messages       ChatMessage[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId, isArchived, updatedAt])
  @@index([projectId, isArchived, updatedAt])
  @@index([type, visibility])
  @@index([lastMessageAt])
}

model ChatChannelMember {
  id                String                @id @default(cuid())
  channelId         String
  userId            String
  role              ChatMemberRole        @default(MEMBER)
  notificationLevel ChatNotificationLevel @default(ALL)
  lastReadSequence  BigInt                @default(0)
  lastReadAt        DateTime?
  mutedUntil        DateTime?
  isActive          Boolean               @default(true)
  removedAt         DateTime?
  channel           ChatChannel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([channelId, userId])
  @@index([userId, isActive, updatedAt])
  @@index([channelId, isActive, role])
}

model ChatMessage {
  id              String                @id @default(cuid())
  channelId       String
  authorId        String
  deletedById     String?
  parentId        String?
  clientMessageId String?
  sequence        BigInt
  body            String
  format          ChatMessageFormat     @default(PLAIN_TEXT)
  replyCount      Int                   @default(0)
  version         Int                   @default(1)
  metadata        Json?
  editedAt        DateTime?
  deletedAt       DateTime?
  channel         ChatChannel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author          User                  @relation("ChatMessageAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  deletedBy       User?                 @relation("ChatMessageDeleter", fields: [deletedById], references: [id], onDelete: SetNull)
  parent          ChatMessage?          @relation("ChatMessageReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies         ChatMessage[]         @relation("ChatMessageReplies")
  revisions       ChatMessageRevision[]
  mentions        ChatMention[]
  reactions       ChatReaction[]
  files           ChatMessageFile[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([channelId, sequence])
  @@unique([channelId, clientMessageId])
  @@index([channelId, createdAt])
  @@index([parentId, createdAt])
  @@index([authorId, createdAt])
  @@index([channelId, deletedAt, sequence])
}

model ChatMessageRevision {
  id           String      @id @default(cuid())
