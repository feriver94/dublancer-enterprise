  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([userId, organizationId, purpose, policyVersion])
  @@index([organizationId, purpose, status])
  @@index([userId, purpose, status])
}

model DataRetentionPolicy {
  id               String       @id @default(cuid())
  organizationId   String
  resourceType     String
  retentionDays    Int
  legalHoldDefault Boolean      @default(false)
  configuration    Json?
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([organizationId, resourceType])
  @@index([organizationId, retentionDays])
}

model AnalyticsEvent {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  projectId      String?
  eventType      String
  properties     Json?
  occurredAt     DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId, eventType, occurredAt])
  @@index([projectId, eventType, occurredAt])
  @@index([userId, occurredAt])
}

model AnalyticsDailyMetric {
  id             String       @id @default(cuid())
  organizationId String
  date           DateTime
  metric         String
  dimensionKey   String       @default("all")
  value          BigInt
  metadata       Json?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, date, metric, dimensionKey])
  @@index([organizationId, metric, date])
}

enum AnalyticsAggregationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model AnalyticsAggregationRun {
  id                  String                     @id @default(cuid())
  organizationId      String
  requestedById       String?
  rangeStart          DateTime
  rangeEnd            DateTime
  timezone            String                     @default("Asia/Dubai")
  status              AnalyticsAggregationStatus @default(PENDING)
  idempotencyKey      String
  processedEventCount Int                        @default(0)
  metricCount         Int                        @default(0)
  startedAt           DateTime?
  completedAt         DateTime?
  errorMessage        String?
  organization        Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedBy         User?                      @relation("AnalyticsRunRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, status, createdAt])
  @@index([organizationId, rangeStart, rangeEnd])
}

model DataExportJob {
  id             String           @id @default(cuid())
  organizationId String
  requestedById  String
  type           String
  status         DataExportStatus @default(QUEUED)
  filters        Json?
  storageKey     String?
  checksumSha256 String?
  expiresAt      DateTime?
  errorMessage   String?
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedBy    User             @relation(fields: [requestedById], references: [id], onDelete: Restrict)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId, status, createdAt])
  @@index([requestedById, createdAt])
  @@index([expiresAt])
}

model BackgroundJob {
  id               String              @id @default(cuid())
  organizationId   String?
  type             String
  status           BackgroundJobStatus @default(PENDING)
  payload          Json
  attempts         Int                 @default(0)
  maxAttempts      Int                 @default(10)
  availableAt      DateTime            @default(now())
  deduplicationKey String?             @unique
  lockedAt         DateTime?
  lockedBy         String?
  leaseExpiresAt   DateTime?
  heartbeatAt      DateTime?
  lastError        String?
  completedAt      DateTime?
  organization     Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deadLetter       DeadLetterJob?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([status, availableAt])
  @@index([organizationId, type, createdAt])
  @@index([lockedAt])
  @@index([status, leaseExpiresAt])
}

model DeadLetterJob {
  id            String        @id @default(cuid())
  originalJobId String        @unique
  job           BackgroundJob @relation(fields: [originalJobId], references: [id], onDelete: Cascade)
  snapshot      Json
  reason        String
  failedAt      DateTime      @default(now())

  @@index([failedAt])
}

model IdempotencyRecord {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  scope          String
  key            String
  requestHash    String
  responseStatus Int?
  responseBody   Json?
  expiresAt      DateTime
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, scope, key])
  @@index([expiresAt])
  @@index([userId, createdAt])
}

model WorkGraphNode {
  id             String            @id @default(cuid())
  organizationId String
  projectId      String?
  type           WorkGraphNodeType
  externalId     String
  label          String
  fingerprint    String
  properties     Json?
  isActive       Boolean           @default(true)
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  outgoingEdges  WorkGraphEdge[]   @relation("WorkGraphEdgeFrom")
  incomingEdges  WorkGraphEdge[]   @relation("WorkGraphEdgeTo")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([organizationId, type, externalId])
  @@index([organizationId, type, isActive])
  @@index([projectId, type])
  @@index([fingerprint])
}

model WorkGraphEdge {
  id             String            @id @default(cuid())
  organizationId String
  fromNodeId     String
  toNodeId       String
  type           WorkGraphEdgeType
  weight         Float             @default(1)
  properties     Json?
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromNode       WorkGraphNode     @relation("WorkGraphEdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode         WorkGraphNode     @relation("WorkGraphEdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([organizationId, fromNodeId, toNodeId, type])
  @@index([organizationId, type])
  @@index([fromNodeId, type])
  @@index([toNodeId, type])
}

model WorkflowDefinition {
  id               String                   @id @default(cuid())
  organizationId   String
  key              String
  name             String
  description      String?
  status           WorkflowDefinitionStatus @default(DRAFT)
  activeVersion    Int?
  concurrencyLimit Int                      @default(10)
  timeoutSeconds   Int                      @default(3600)
  createdById      String
  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy        User                     @relation("WorkflowDefinitionCreator", fields: [createdById], references: [id], onDelete: Restrict)
  versions         WorkflowVersion[]
  runs             WorkflowRun[]
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId, status, updatedAt])
  @@index([createdById, createdAt])
}

model WorkflowVersion {
  id           String             @id @default(cuid())
  definitionId String
  version      Int
  checksum     String
  graph        Json
  publishedAt  DateTime?
  definition   WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  runs         WorkflowRun[]
  createdAt    DateTime           @default(now())

  @@unique([definitionId, version])
  @@unique([definitionId, checksum])
  @@index([checksum])
}

model WorkflowRun {
  id             String             @id @default(cuid())
  organizationId String
  definitionId   String
  versionId      String
  startedById    String
  status         WorkflowRunStatus  @default(QUEUED)
  idempotencyKey String
  correlationId  String
  input          Json?
  output         Json?
  error          Json?
  availableAt    DateTime           @default(now())
  startedAt      DateTime?
  finishedAt     DateTime?
  timeoutAt      DateTime?
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  definition     WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Restrict)
  version        WorkflowVersion    @relation(fields: [versionId], references: [id], onDelete: Restrict)
  startedBy      User               @relation("WorkflowRunStarter", fields: [startedById], references: [id], onDelete: Restrict)
  steps          WorkflowStepRun[]
  approvals      WorkflowApproval[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([organizationId, definitionId, idempotencyKey])
  @@index([organizationId, status, availableAt])
  @@index([definitionId, status, createdAt])
  @@index([correlationId])
}

model WorkflowStepRun {
  id          String             @id @default(cuid())
  runId       String
  stepKey     String
  stepType    String
  status      WorkflowStepStatus @default(PENDING)
  attempt     Int                @default(0)
  maxAttempts Int                @default(3)
  config      Json?
  input       Json?
  output      Json?
  error       Json?
  availableAt DateTime           @default(now())
  lockedAt    DateTime?
  lockedBy    String?
  startedAt   DateTime?
  finishedAt  DateTime?
  run         WorkflowRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  approval    WorkflowApproval?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([runId, stepKey])
  @@index([status, availableAt])
  @@index([runId, status])
  @@index([lockedAt])
}

model WorkflowApproval {
  id             String                   @id @default(cuid())
  organizationId String
  runId          String
  stepRunId      String                   @unique
  requestedById  String
  decidedById    String?
  decision       WorkflowApprovalDecision @default(PENDING)
  reason         String
  comment        String?
  expiresAt      DateTime?
  decidedAt      DateTime?
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  run            WorkflowRun              @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepRun        WorkflowStepRun          @relation(fields: [stepRunId], references: [id], onDelete: Cascade)
  requestedBy    User                     @relation("WorkflowApprovalRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  decidedBy      User?                    @relation("WorkflowApprovalDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([organizationId, decision, createdAt])
  @@index([runId, decision])
  @@index([expiresAt])
}

model TalentMatch {
  id                  String             @id @default(cuid())
  organizationId      String
  listingId           String
  freelancerProfileId String
  status              TalentMatchStatus  @default(SUGGESTED)
  score               Int
  skillScore          Int
  experienceScore     Int
  availabilityScore   Int
  explanation         Json
  excludedAttributes  String[]           @default(["displayName", "email", "gender", "age", "nationality", "religion", "disability", "maritalStatus"])
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listing             MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  freelancerProfile   FreelancerProfile  @relation(fields: [freelancerProfileId], references: [id], onDelete: Cascade)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([organizationId, listingId, freelancerProfileId])
  @@index([organizationId, status, score])
  @@index([listingId, score])
  @@index([freelancerProfileId, status])
}

model RateLimitBucket {
  id             String        @id @default(cuid())
  organizationId String?
  key            String        @unique
  count          Int           @default(0)
  windowStart    DateTime
  expiresAt      DateTime
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId, expiresAt])
  @@index([expiresAt])
}
