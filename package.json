{
  "name": "dublancer-enterprise",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --quiet",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "verify:locales": "node scripts/verify-locales.mjs",
    "verify:security": "node scripts/verify-security.mjs",
    "verify:migrations": "node scripts/verify-migrations.mjs",
    "verify:secrets": "node scripts/verify-secrets.mjs",
    "verify:release": "prisma validate && prisma generate && npm run verify:migrations && npm run verify:locales && npm run verify:security && npm run verify:secrets && npm test && tsc --noEmit && eslint --quiet && next build",
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "next": "16.2.9",
    "next-intl": "^4.13.2",
    "pg": "^8.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "prisma": "^7.8.0",
    "tailwindcss": "latest",
    "typescript": "latest"
  }
}
