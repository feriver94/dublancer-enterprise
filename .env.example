DATABASE_URL="postgresql://dublancer:change-me@localhost:5432/dublancer?schema=public"
REDIS_URL="redis://localhost:6379"
APP_BASE_URL="http://localhost:3000"
NODE_ENV="development"
EXPOSE_DEVELOPMENT_TOKENS="false"
AUTH_SECRET="replace-with-at-least-32-random-bytes"
INTERNAL_PUBLISHER_SECRET="replace-with-high-entropy-secret"
INTERNAL_NOTIFICATION_SECRET="replace-with-high-entropy-secret"
INTERNAL_CHAT_MAINTENANCE_SECRET="replace-with-high-entropy-secret"
INTERNAL_WORKER_SECRET="replace-with-high-entropy-secret"

# Provider-neutral storage signing broker
STORAGE_PROVIDER_KEY="s3-compatible"
STORAGE_SIGNING_ENDPOINT="https://storage-broker.example.com"
STORAGE_SIGNING_TOKEN="replace-me"

# OpenAI-compatible AI endpoint (may be any compatible provider)
AI_PROVIDER_KEY="enterprise-ai"
AI_PROVIDER_BASE_URL="https://ai-provider.example.com/v1"
AI_PROVIDER_API_KEY="replace-me"

# Payment orchestration provider/broker
PAYMENT_PROVIDER_KEY="payment-broker"
PAYMENT_PROVIDER_BASE_URL="https://payments.example.com"
PAYMENT_PROVIDER_API_KEY="replace-me"
PAYMENT_WEBHOOK_SECRET="replace-me"

# Outbound notification broker (email/SMS/push)
NOTIFICATION_PROVIDER_BASE_URL="https://notifications.example.com"
NOTIFICATION_PROVIDER_API_KEY="replace-me"

# Malware scanning broker
FILE_SCAN_PROVIDER_BASE_URL="https://scanner.example.com"
FILE_SCAN_PROVIDER_API_KEY="replace-me"
FILE_SCAN_WEBHOOK_SECRET="replace-me"

# Optional scalable runtime adapters
QUEUE_PROVIDER_KEY="database-outbox"
SEARCH_PROVIDER_KEY="postgresql"
CACHE_PROVIDER_KEY="redis"
